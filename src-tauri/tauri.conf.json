{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beam",
  "version": "0.1.2",
  "identifier": "com.beam.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beam",
        "width": 1100,
        "height": 740,
        "minWidth": 640,
        "minHeight": 520,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/SawcyD/Beam/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdERUFDRDZGMjU0MEQzN0MKUldSODAwQWxiODNxZmI3UzMwN3pRTFVQZkF6R212NkIyUHU3ZnppVENmbVl1dEhxbUdGWWxrdTcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
